{
  "name": "mermaid-cinema",
  "version": "0.2.0",
  "description": "Mermaid diagrams to SVG, PNG, PDF, GIF, MP4. No browser required for static output.",
  "type": "module",
  "bin": {
    "mermaid-cinema": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "cli",
    "svg",
    "png",
    "gif",
    "mp4",
    "animation",
    "remotion"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "citty": "^0.2.1",
    "jsdom": "^29.0.1",
    "linkedom": "^0.18.12",
    "mermaid": "^11.13.0",
    "pdf-lib": "^1.17.1"
  },
  "peerDependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/paths": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "remotion": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@remotion/bundler": { "optional": true },
    "@remotion/paths": { "optional": true },
    "@remotion/renderer": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "remotion": { "optional": true }
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.443",
    "@remotion/cli": "^4.0.443",
    "@remotion/paths": "^4.0.443",
    "@remotion/renderer": "^4.0.443",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.443",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "unbuild": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
